#!/usr/bin/env bash
# Creates GCP service accounts for GitHub Actions deployment:
#   1. github-deploy   — used by CI to push images and deploy
#   2. fqf-SA     — used by Cloud Run at runtime (Firestore access)
#
# Also sets the required GitHub repository secrets (GCP_SA_KEY, GCP_PROJECT).
#
# Prerequisites:
#   - gcloud CLI authenticated with project owner permissions
#   - gh CLI authenticated with repo access
#   - GCP project already created (run setup-gcp-project first)
#
# Usage:
#   ./scripts/set-gcloud-creds-for-deploy          # create (idempotent)
#   ./scripts/set-gcloud-creds-for-deploy --new    # delete and recreate
#   ./scripts/set-gcloud-creds-for-deploy --clear  # delete only
set -euo pipefail

PROJECT=$(gcloud config get-value project 2>/dev/null)
if [[ -z "$PROJECT" ]]; then
    echo "ERROR: No GCP project set. Run: gcloud config set project <project-id>"
    exit 1
fi

DEPLOY_SA_NAME="github-deploy"
DEPLOY_SA_EMAIL="${DEPLOY_SA_NAME}@${PROJECT}.iam.gserviceaccount.com"
RUNTIME_SA_NAME="fqf-SA"
RUNTIME_SA_EMAIL="${RUNTIME_SA_NAME}@${PROJECT}.iam.gserviceaccount.com"
REPO_NAME="container-images"
REGION="${GCP_REGION:-us-central1}"
KEY_FILE=$(mktemp)

DEPLOY_ROLES=(
    "roles/run.admin"
    "roles/iam.serviceAccountUser"
)

usage() {
    echo "Usage: $(basename "$0") [--new | --clear]"
    echo ""
    echo "  (no args)  Create SAs and set GitHub secrets (idempotent)"
    echo "  --new      Delete existing SAs and secrets, then recreate"
    echo "  --clear    Delete existing SAs and secrets only"
    exit 1
}

cleanup() { rm -f "$KEY_FILE"; }
trap cleanup EXIT

# ── Helpers ──────────────────────────────────────────────────────

sa_exists() {
    gcloud iam service-accounts describe "$1" --project="$PROJECT" &>/dev/null
}

secrets_exist() {
    gh secret list 2>/dev/null | grep -q "GCP_SA_KEY"
}

# Check if a SA already has a specific project-level role
has_project_role() {
    local email=$1 role=$2
    gcloud projects get-iam-policy "$PROJECT" \
        --flatten="bindings[].members" \
        --filter="bindings.role=${role} AND bindings.members=serviceAccount:${email}" \
        --format="value(bindings.role)" 2>/dev/null | grep -q .
}

# Check if a SA already has a repo-level role
has_repo_role() {
    local email=$1 repo=$2 role=$3
    gcloud artifacts repositories get-iam-policy "$repo" \
        --location="$REGION" \
        --project="$PROJECT" \
        --flatten="bindings[].members" \
        --filter="bindings.role=${role} AND bindings.members=serviceAccount:${email}" \
        --format="value(bindings.role)" 2>/dev/null | grep -q .
}

grant_project_role() {
    local email=$1 role=$2
    if has_project_role "$email" "$role"; then
        echo "  ${role} — already bound"
    else
        echo "  Granting ${role}..."
        gcloud projects add-iam-policy-binding "$PROJECT" \
            --member="serviceAccount:${email}" \
            --role="$role" \
            --quiet &>/dev/null
    fi
}

create_deploy_sa() {
    echo "Creating deploy service account ${DEPLOY_SA_NAME}..."
    gcloud iam service-accounts create "$DEPLOY_SA_NAME" \
        --project="$PROJECT" \
        --display-name="GitHub Actions Deploy"

    for role in "${DEPLOY_ROLES[@]}"; do
        grant_project_role "$DEPLOY_SA_EMAIL" "$role"
    done

    if has_repo_role "$DEPLOY_SA_EMAIL" "$REPO_NAME" "roles/artifactregistry.writer"; then
        echo "  Artifact Registry writer — already bound"
    else
        echo "  Granting Artifact Registry writer on ${REPO_NAME}..."
        gcloud artifacts repositories add-iam-policy-binding "$REPO_NAME" \
            --location="$REGION" \
            --project="$PROJECT" \
            --member="serviceAccount:${DEPLOY_SA_EMAIL}" \
            --role="roles/artifactregistry.writer" \
            --quiet &>/dev/null
    fi
}

create_runtime_sa() {
    echo "Creating runtime service account ${RUNTIME_SA_NAME}..."
    gcloud iam service-accounts create "$RUNTIME_SA_NAME" \
        --project="$PROJECT" \
        --display-name="FQF Cloud Run Runtime"

    grant_project_role "$RUNTIME_SA_EMAIL" "roles/datastore.user"
}

delete_sa() {
    local email=$1 name=$2
    if sa_exists "$email"; then
        echo "Deleting service account ${name}..."
        gcloud iam service-accounts delete "$email" \
            --project="$PROJECT" --quiet
    fi
}

set_secrets() {
    echo "Generating key and setting GitHub secrets..."
    gcloud iam service-accounts keys create "$KEY_FILE" \
        --iam-account="$DEPLOY_SA_EMAIL" --quiet

    gh secret set GCP_SA_KEY < "$KEY_FILE"
    gh secret set GCP_PROJECT --body "$PROJECT"
    echo "GitHub secrets GCP_SA_KEY and GCP_PROJECT set."
}

clear_secrets() {
    echo "Removing GitHub secrets..."
    gh secret delete GCP_SA_KEY 2>/dev/null && echo "  Deleted GCP_SA_KEY" || echo "  GCP_SA_KEY not found"
    gh secret delete GCP_PROJECT 2>/dev/null && echo "  Deleted GCP_PROJECT" || echo "  GCP_PROJECT not found"
}

# ── Main ─────────────────────────────────────────────────────────

MODE="${1:-}"

case "$MODE" in
    --clear)
        clear_secrets
        delete_sa "$DEPLOY_SA_EMAIL" "$DEPLOY_SA_NAME"
        delete_sa "$RUNTIME_SA_EMAIL" "$RUNTIME_SA_NAME"
        echo "Done. Credentials cleared."
        ;;
    --new)
        clear_secrets
        delete_sa "$DEPLOY_SA_EMAIL" "$DEPLOY_SA_NAME"
        delete_sa "$RUNTIME_SA_EMAIL" "$RUNTIME_SA_NAME"
        create_deploy_sa
        create_runtime_sa
        set_secrets
        echo "Done. Fresh credentials created."
        ;;
    "")
        if ! sa_exists "$DEPLOY_SA_EMAIL"; then
            create_deploy_sa
        else
            echo "Deploy SA ${DEPLOY_SA_NAME} already exists — ensuring bindings..."
            for role in "${DEPLOY_ROLES[@]}"; do
                grant_project_role "$DEPLOY_SA_EMAIL" "$role"
            done
            if has_repo_role "$DEPLOY_SA_EMAIL" "$REPO_NAME" "roles/artifactregistry.writer"; then
                echo "  Artifact Registry writer — already bound"
            else
                echo "  Granting Artifact Registry writer on ${REPO_NAME}..."
                gcloud artifacts repositories add-iam-policy-binding "$REPO_NAME" \
                    --location="$REGION" \
                    --project="$PROJECT" \
                    --member="serviceAccount:${DEPLOY_SA_EMAIL}" \
                    --role="roles/artifactregistry.writer" \
                    --quiet &>/dev/null
            fi
        fi
        if ! sa_exists "$RUNTIME_SA_EMAIL"; then
            create_runtime_sa
        else
            echo "Runtime SA ${RUNTIME_SA_NAME} already exists — ensuring bindings..."
            grant_project_role "$RUNTIME_SA_EMAIL" "roles/datastore.user"
        fi
        if secrets_exist; then
            echo "GitHub secrets already set. Skipping key generation."
            echo "Use --new to recreate everything from scratch."
        else
            set_secrets
        fi
        echo "Done."
        ;;
    *)
        usage
        ;;
esac
