#!/usr/bin/env bash
# Creates GCP service accounts for deploy and runtime, then sets GitHub secrets.
# Usage: ./scripts/set-gcloud-creds-for-deploy <PROJECT_ID> <GITHUB_REPO>
#   GITHUB_REPO  owner/repo format, e.g. mgreenberg/fqf
set -euo pipefail

PROJECT_ID="${1:-}"
GITHUB_REPO="${2:-}"
REGION="${3:-us-central1}"

DEPLOY_SA="github-deploy"
RUNTIME_SA="fqf-runtime"
ARTIFACT_REPO="fqf"

if [[ -z "$PROJECT_ID" || -z "$GITHUB_REPO" ]]; then
    echo "Usage: $0 <PROJECT_ID> <GITHUB_REPO> [REGION]"
    echo "  PROJECT_ID   GCP project ID"
    echo "  GITHUB_REPO  GitHub repo in owner/repo format"
    echo "  REGION       GCP region (default: us-central1)"
    exit 1
fi

DEPLOY_SA_EMAIL="${DEPLOY_SA}@${PROJECT_ID}.iam.gserviceaccount.com"
RUNTIME_SA_EMAIL="${RUNTIME_SA}@${PROJECT_ID}.iam.gserviceaccount.com"

echo "==> Creating deploy service account: $DEPLOY_SA_EMAIL"
gcloud iam service-accounts create "$DEPLOY_SA" \
    --project="$PROJECT_ID" \
    --display-name="GitHub Deploy SA" \
    || echo "Service account already exists — continuing"

echo "==> Granting deploy SA roles..."
for role in "roles/run.admin" "roles/iam.serviceAccountUser"; do
    gcloud projects add-iam-policy-binding "$PROJECT_ID" \
        --member="serviceAccount:${DEPLOY_SA_EMAIL}" \
        --role="$role" \
        --quiet
done

gcloud artifacts repositories add-iam-policy-binding "$ARTIFACT_REPO" \
    --location="$REGION" \
    --project="$PROJECT_ID" \
    --member="serviceAccount:${DEPLOY_SA_EMAIL}" \
    --role="roles/artifactregistry.writer" \
    --quiet

echo "==> Creating runtime service account: $RUNTIME_SA_EMAIL"
gcloud iam service-accounts create "$RUNTIME_SA" \
    --project="$PROJECT_ID" \
    --display-name="FQF Runtime SA" \
    || echo "Service account already exists — continuing"

echo "==> Granting runtime SA Firestore access..."
gcloud projects add-iam-policy-binding "$PROJECT_ID" \
    --member="serviceAccount:${RUNTIME_SA_EMAIL}" \
    --role="roles/datastore.user" \
    --quiet

echo "==> Generating deploy SA key..."
KEY_FILE=$(mktemp /tmp/gcp-sa-key-XXXXXX.json)
gcloud iam service-accounts keys create "$KEY_FILE" \
    --iam-account="$DEPLOY_SA_EMAIL" \
    --project="$PROJECT_ID"

echo "==> Setting GitHub secrets for repo: $GITHUB_REPO"
gh secret set GCP_SA_KEY --repo "$GITHUB_REPO" < "$KEY_FILE"
gh secret set GCP_PROJECT --repo "$GITHUB_REPO" --body "$PROJECT_ID"

rm -f "$KEY_FILE"
echo "  Key file deleted."

echo ""
echo "Service account setup complete."
echo "  Deploy SA:   $DEPLOY_SA_EMAIL"
echo "  Runtime SA:  $RUNTIME_SA_EMAIL"
echo ""
echo "GitHub secrets set: GCP_SA_KEY, GCP_PROJECT"
echo ""
echo "In Cloud Run deploy, pass --service-account=${RUNTIME_SA_EMAIL} so the"
echo "runtime SA (not the deploy SA) is used for Firestore access."
